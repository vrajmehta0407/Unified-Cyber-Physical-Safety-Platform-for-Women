# ============================================================
# CyberShield — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# ── Backend ──────────────────────────────────────────────────
DATABASE_URL=postgresql://cybershield:cybershield@localhost:5432/cybershield
SECRET_KEY=change-me-to-a-random-32-char-secret-key
OTP_EXPIRY_SECONDS=300
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── AI Engine ────────────────────────────────────────────────
AI_ENGINE_URL=http://localhost:8001
# (In Docker: http://ai-engine:8001 — set automatically)

# ── Evidence Storage (AES-256) ───────────────────────────────
EVIDENCE_ENCRYPTION_KEY=32-byte-aes-key-change-in-prod!!

# ── AWS S3 (for production evidence storage) ─────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=cybershield-evidence
AWS_REGION=ap-south-1

# ── Firebase (optional — for real push notifications) ────────
FIREBASE_CREDENTIALS_PATH=./firebase/firebaseServiceAccount.json
FIREBASE_DATABASE_URL=https://cybershield.firebaseio.com

# ── ERSS 112 Integration (simulated) ─────────────────────────
ERSS_WEBHOOK_URL=http://localhost:9000/erss/alert

# ── Google Maps (mobile app) ─────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── Dashboard ────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws
